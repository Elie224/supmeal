# ===== Application =====
APP_ENV=production
APP_NAME=SUPMEAL
APP_URL=https://supmeal.example.com

# ===== Backend (FastAPI) =====
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8765
BACKEND_CORS_ORIGINS=https://supmeal.example.com

# ===== Securite (OBLIGATOIRE EN PRODUCTION) =====
# Generees aleatoirement (>= 64 caracteres recommandes)
SECRET_KEY=replace-with-random-secret-64chars-min
JWT_SECRET=replace-with-random-jwt-secret-64chars-min
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ===== Base de donnees (PostgreSQL) =====
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=supmeal
POSTGRES_USER=supmeal
POSTGRES_PASSWORD=replace-with-strong-password

# ===== Stockage images =====
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=5

# ===== OAuth2 - Google =====
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api.supmeal.example.com/api/v1/auth/oauth/google/callback

# ===== OAuth2 - GitHub =====
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=https://api.supmeal.example.com/api/v1/auth/oauth/github/callback

# ===== SMTP (verification email) =====
# Exemple Brevo SMTP relay
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USERNAME=your-brevo-login
SMTP_PASSWORD=your-brevo-smtp-key
SMTP_USE_STARTTLS=true
SMTP_USE_SSL=false
SMTP_FROM_EMAIL=no-reply@supmeal.example.com
SMTP_FROM_NAME=SUPMEAL
