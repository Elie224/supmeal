# ===== Application =====
APP_ENV=development
APP_NAME=SUPMEAL
APP_URL=http://localhost:5173

# ===== Backend (FastAPI) =====
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ===== Securite (REMPLACER EN PRODUCTION) =====
SECRET_KEY=change-me-please-generate-a-random-64-chars-string
JWT_SECRET=change-me-please-generate-a-random-64-chars-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ===== Base de donnees (PostgreSQL) =====
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=supmeal
POSTGRES_USER=supmeal
POSTGRES_PASSWORD=change-me-please

# ===== Stockage images =====
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=5

# ===== OAuth2 - Google =====
# Creer sur https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/google/callback

# ===== OAuth2 - GitHub =====
# Creer sur https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/github/callback

# ===== OAuth2 - Microsoft =====
# Creer sur https://portal.azure.com (App registrations)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/microsoft/callback

